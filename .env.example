# Frontend (Vite) — baked in at build time for production
# Local dev: create .env.local with:
# VITE_CHAT_API_URL=http://localhost:8787
# Leave unset to use only the built-in rule-based assistant (no network).
# VITE_CHAT_API_URL=

# Server (run from repo root: npm run server:dev)
# Copy to .env in repo root and use: node --env-file=.env server/index.js
# Or export variables in your shell / hosting dashboard.
#
# CHAT_MODEL_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL_API_KEY=sk-...
# CHAT_MODEL_NAME=gpt-4o-mini
#
# Ollama example:
# CHAT_MODEL_BASE_URL=http://127.0.0.1:11434/v1
# CHAT_MODEL_NAME=llama3.2
# CHAT_MODEL_API_KEY=
#
# PORT=8787
# CORS_ORIGIN=http://localhost:5173,https://your-org.github.io
# CHAT_MAX_CONTEXT_CHARS=24000
